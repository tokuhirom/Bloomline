{
  "name": "bloomline",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepare": "simple-git-hooks"
